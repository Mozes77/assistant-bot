# ==============================
# Telegram Bot Environment Config
# ==============================

# Обязательно: токен Telegram-бота (получить у @BotFather)
TELEGRAM_TOKEN=YOUR_TELEGRAM_TOKEN

# Обязательно: API-ключ OpenAI
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Обязательно: API-ключ DaData
# Примечание: main.py поддерживает и DADATA_API_KEY, и DADATA_TOKEN
DADATA_API_KEY=YOUR_DADATA_API_KEY

# Критично для интеграции с Google Apps Script
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/AKfycbwQkC2kc8V9oD1fn7Ug8cLUGqnw8S0ZuCFIkBgRZcr1V3dNeFRV-JFAPOt45DBP5p-z/exec

# Необязательно: модель OpenAI (по умолчанию gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
